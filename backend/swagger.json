    "/api/users/update": {
      "patch": {
        "tags": ["Users"],
        "summary": "Update user information",
        "security": [{ "BearerAuth": [] }],
        "requestBody": {
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "properties": {
