    "/api/drinks/own/add": {
      "post": {
        "tags": ["Drinks"],
        "summary": "Add a new drink",
        "security": [{ "BearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "required": ["drink", "category", "glass", "instructions"],
                "properties": {
                  "drink": {
                    "type": "string",
                    "example": "My Cocktail"
                  },
                  "alcoholic": {
                    "type": "string",
                    "example": "Alcoholic"
                  },
                  "category": {
                    "type": "string",
                    "example": "Cocktail"
                  },
                  "glass": {
                    "type": "string",
                    "example": "Highball glass"
                  },
                  "description": {
                    "type": "string",
                    "example": "A delicious cocktail"
                  },
                  "instructions": {
                    "type": "string",
                    "example": "Mix all ingredients"
                  },
                  "drinkThumb": {
                    "type": "string",
                    "format": "binary",
                    "description": "Drink image"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Drink created successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Drink"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "500": {
            "description": "Server error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
