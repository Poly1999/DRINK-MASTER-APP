                  "birthday": {
                    "type": "string",
                    "format": "date",
                    "example": "1990-01-01"
                  },
                  "avatar": {
                    "type": "string",
                    "format": "binary",
                    "description": "User avatar image"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "User updated successfully",
